{
  "expo": {
    "name": "Rift",
    "slug": "rift",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EB7A9F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rift.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Rift uses your location to find nearby photo requests.",
        "NSCameraUsageDescription": "Rift uses your camera to capture photos and videos for requests.",
        "NSMicrophoneUsageDescription": "Rift uses your microphone for video capture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EB7A9F"
      },
      "package": "com.rift.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rift uses your location to find nearby photo requests."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Rift uses your camera to capture photos and videos.",
          "microphonePermission": "Rift uses your microphone for video capture."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#EB7A9F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "rift",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "729c8f5b-fdaa-42d3-bb6d-a1d4721da8f4"
      }
    },
    "owner": "zyenge"
  }
}
